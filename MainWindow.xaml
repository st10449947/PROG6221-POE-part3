<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CybersecurityChatbot"
        xmlns:converters="clr-namespace:CybersecurityChatbot.Converters"
        mc:Ignorable="d"
        Title="CybersecurityBot"
        Height="700"
        Width="900"
        Background="Black"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Converter for Boolean to Visibility -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Converter for String to Visibility -->
        <converters:StringToVisibilityConverter x:Key="StringToVisibility"/>

        <!-- Style for TabItem headers -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#111B21"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#25D366"
                                BorderThickness="0,0,0,0"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,2,0">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#202C33"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="0,0,0,3"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#202C33"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Buttons with rounded corners -->
        <Style x:Key="GreenButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#25D366"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Danger Buttons -->
        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Gray Buttons -->
        <Style x:Key="GrayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4A4A4A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Gold Buttons -->
        <Style x:Key="GoldButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFD700"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============================================ -->
        <!-- HEADER -->
        <!-- ============================================ -->
        <Grid Grid.Row="0" Background="#111B21">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="🛡️ Cybersecurity Chatbot"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#25D366"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- PROFILE IMAGE -->
            <Border Grid.Column="1"
                    Width="45"
                    Height="45"
                    CornerRadius="22.5"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,15,0"
                    BorderBrush="#25D366"
                    BorderThickness="2">
                <Image Source="pack://application:,,,/Images/Profile.jpeg"
                       Stretch="UniformToFill"/>
            </Border>
        </Grid>

        <!-- ============================================ -->
        <!-- ASCII AREA -->
        <!-- ============================================ -->
        <Border Grid.Row="1"
                Background="Black"
                Padding="5">
            <TextBlock FontFamily="Consolas"
                       FontSize="9"
                       Foreground="#25D366"
                       HorizontalAlignment="Center"
                       TextAlignment="Left"
                       xml:space="preserve">
  ____      _                                        _ _              
 / ___|   _| |__   ___ _ __ ___  ___  ___ _   _ _ __(_) |_ _   _      
| |  | | | | '_ \ / _ \ '__/ __|/ _ \/ __| | | | '__| | __| | | |     
| |__| |_| | |_) |  __/ |  \__ \  __/ (__| |_| | |  | | |_| |_| |     
 \____\__, |_.__/ \___|_|  |___/\___|\___|\__,_|_|  |_|\__|\__, |      
      |___/                                                 |___/

            </TextBlock>
        </Border>

        <!-- ============================================ -->
        <!-- TAB CONTROL - MAIN CONTENT -->
        <!-- ============================================ -->
        <TabControl Grid.Row="2" 
                    Background="#111B21"
                    Foreground="White"
                    BorderThickness="0">

            <!-- ========================================= -->
            <!-- TAB 1: CHAT -->
            <!-- ========================================= -->
            <TabItem Header="💬 Chat">
                <Grid Background="#111B21">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- CHAT DISPLAY -->
                    <Border Grid.Row="0"
                            Background="#0A0A0A"
                            Margin="5"
                            CornerRadius="10">
                        <ScrollViewer x:Name="ChatScroller"
                                      VerticalScrollBarVisibility="Auto"
                                      Background="Transparent">
                            <StackPanel x:Name="ChatPanel"
                                        Margin="10"/>
                        </ScrollViewer>
                    </Border>

                    <!-- INPUT AREA -->
                    <Grid Grid.Row="1"
                          Background="#111B21"
                          Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#202C33"
                                CornerRadius="20"
                                Margin="0,0,10,0">
                            <TextBox x:Name="UserInput"
                                     Background="Transparent"
                                     Foreground="White"
                                     CaretBrush="White"
                                     BorderThickness="0"
                                     Padding="15"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     KeyDown="UserInput_KeyDown"
                                     TextChanged="UserInput_TextChanged"/>
                        </Border>

                        <Button Grid.Column="1"
                                Content="Send"
                                Style="{StaticResource GreenButtonStyle}"
                                Padding="0"
                                Click="SendButton_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ========================================= -->
            <!-- TAB 2: TASKS -->
            <!-- ========================================= -->
            <TabItem Header="📋 Tasks">
                <Grid Margin="10" Background="#111B21">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Grid.Row="0"
                               Text="Task Assistant"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#25D366"
                               Margin="0,0,0,10"/>

                    <!-- Add Task Section -->
                    <Border Grid.Row="1"
                            Background="#202C33"
                            CornerRadius="10"
                            Padding="10"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="2"
                                       Text="➕ Add New Task"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,10"/>

                            <TextBox x:Name="TaskTitleBox"
                                     Grid.Row="1"
                                     Grid.ColumnSpan="2"
                                     Background="#111B21"
                                     Foreground="White"
                                     BorderBrush="#25D366"
                                     BorderThickness="1"
                                     Padding="10"
                                     Margin="0,0,0,8"
                                     FontSize="14">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Text" Value="Enter task title..."/>
                                        <Setter Property="Foreground" Value="Gray"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="Text" Value=""/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <TextBox x:Name="TaskDescBox"
                                     Grid.Row="2"
                                     Grid.ColumnSpan="2"
                                     Background="#111B21"
                                     Foreground="White"
                                     BorderBrush="#25D366"
                                     BorderThickness="1"
                                     Padding="10"
                                     Margin="0,0,0,8"
                                     FontSize="14">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Text" Value="Enter description..."/>
                                        <Setter Property="Foreground" Value="Gray"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="Text" Value=""/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <TextBox x:Name="TaskReminderBox"
                                     Grid.Row="3"
                                     Grid.Column="0"
                                     Background="#111B21"
                                     Foreground="White"
                                     BorderBrush="#25D366"
                                     BorderThickness="1"
                                     Padding="10"
                                     Margin="0,0,8,0"
                                     FontSize="14">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Text" Value="Reminder (optional)..."/>
                                        <Setter Property="Foreground" Value="Gray"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="Text" Value=""/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <Button x:Name="AddTaskButton"
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Content="Add Task"
                                    Style="{StaticResource GreenButtonStyle}"
                                    Padding="15,8"
                                    Click="AddTaskButton_Click"/>
                        </Grid>
                    </Border>

                    <!-- Task List -->
                    <Border Grid.Row="2"
                            Background="#202C33"
                            CornerRadius="10"
                            Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="📌 Your Tasks"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,10"/>

                            <Border Grid.Row="1"
                                    Background="#111B21"
                                    CornerRadius="5">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ListBox x:Name="TaskListBox"
                                             Background="Transparent"
                                             Foreground="White"
                                             BorderThickness="0"
                                             SelectionMode="Single"
                                             Margin="2">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#202C33"
                                                        CornerRadius="8"
                                                        Padding="12"
                                                        Margin="0,3">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- Title -->
                                                        <TextBlock Grid.Row="0"
                                                                   Grid.Column="0"
                                                                   Text="{Binding Title}"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"
                                                                   FontSize="14"/>

                                                        <!-- Description -->
                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="0"
                                                                   Text="{Binding Description}"
                                                                   Foreground="Gray"
                                                                   FontSize="12"
                                                                   Margin="0,2,0,2"/>

                                                        <!-- Reminder -->
                                                        <TextBlock Grid.Row="2"
                                                                   Grid.Column="0"
                                                                   Text="{Binding Reminder, StringFormat=🔔 {0}}"
                                                                   Foreground="#25D366"
                                                                   FontSize="11"
                                                                   Visibility="{Binding Reminder, Converter={StaticResource StringToVisibility}}"/>

                                                        <!-- ID and Status -->
                                                        <StackPanel Grid.Row="0"
                                                                    Grid.Column="1"
                                                                    Grid.RowSpan="3"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding Id}"
                                                                       Foreground="Gray"
                                                                       FontSize="10"
                                                                       HorizontalAlignment="Right"/>
                                                            <TextBlock Text="✅ Complete"
                                                                       Foreground="#25D366"
                                                                       FontWeight="Bold"
                                                                       FontSize="11"
                                                                       Visibility="{Binding IsComplete, Converter={StaticResource BoolToVisibility}}"
                                                                       HorizontalAlignment="Right"/>
                                                            <TextBlock Text="⏳ Pending"
                                                                       Foreground="#FFA500"
                                                                       FontWeight="Bold"
                                                                       FontSize="11"
                                                                       Visibility="{Binding IsComplete, Converter={StaticResource BoolToVisibility}}"
                                                                       HorizontalAlignment="Right"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0">
                        <Button x:Name="CompleteTaskButton"
                                Content="✅ Mark Complete"
                                Style="{StaticResource GreenButtonStyle}"
                                Padding="15,10"
                                Margin="0,0,10,0"
                                Click="CompleteTaskButton_Click"/>

                        <Button x:Name="DeleteTaskButton"
                                Content="🗑️ Delete Task"
                                Style="{StaticResource DangerButtonStyle}"
                                Padding="15,10"
                                Margin="0,0,10,0"
                                Click="DeleteTaskButton_Click"/>

                        <Button x:Name="RefreshTasksButton"
                                Content="🔄 Refresh"
                                Style="{StaticResource GrayButtonStyle}"
                                Padding="15,10"
                                Click="RefreshTasksButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ========================================= -->
            <!-- TAB 3: QUIZ -->
            <!-- ========================================= -->
            <TabItem Header="🎯 Quiz">
                <Grid Margin="10" Background="#111B21">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Grid.Row="0"
                               Text="Cybersecurity Quiz"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#25D366"
                               Margin="0,0,0,10"/>

                    <!-- Quiz Content -->
                    <Border Grid.Row="1"
                            Background="#202C33"
                            CornerRadius="10"
                            Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Score Display -->
                            <Grid Grid.Row="0"
                                  Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="QuizScoreText"
                                           Grid.Column="0"
                                           Text="🏆 Score: 0/0"
                                           Foreground="#FFD700"
                                           FontSize="16"
                                           FontWeight="Bold"/>

                                <TextBlock x:Name="QuizProgressText"
                                           Grid.Column="1"
                                           Text="📊 Question: 0/0"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- Question Area -->
                            <Border Grid.Row="1"
                                    Background="#111B21"
                                    CornerRadius="8"
                                    Padding="15">
                                <StackPanel>
                                    <TextBlock x:Name="QuizQuestionText"
                                               Text="Press 'Start Quiz' to begin testing your cybersecurity knowledge!"
                                               Foreground="White"
                                               FontSize="16"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,15"/>

                                    <StackPanel x:Name="QuizOptionsPanel"
                                                Margin="0,0,0,10">
                                        <!-- Options will be dynamically created -->
                                    </StackPanel>

                                    <TextBlock x:Name="QuizFeedbackText"
                                               Foreground="#FFD700"
                                               FontSize="14"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Quiz Buttons -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,10">
                        <Button x:Name="StartQuizButton"
                                Content="🚀 Start Quiz"
                                Style="{StaticResource GreenButtonStyle}"
                                Margin="0,0,10,0"
                                Click="StartQuizButton_Click"/>

                        <Button x:Name="SubmitQuizButton"
                                Content="✅ Submit Answer"
                                Style="{StaticResource GoldButtonStyle}"
                                Margin="0,0,10,0"
                                Click="SubmitQuizButton_Click"
                                Visibility="Collapsed"/>

                        <Button x:Name="NextQuizButton"
                                Content="➡️ Next Question"
                                Style="{StaticResource GreenButtonStyle}"
                                Margin="0,0,10,0"
                                Click="NextQuizButton_Click"
                                Visibility="Collapsed"/>

                        <Button x:Name="ResetQuizButton"
                                Content="🔄 Reset Quiz"
                                Style="{StaticResource GrayButtonStyle}"
                                Click="ResetQuizButton_Click"
                                Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Final Results -->
                    <Border x:Name="QuizResultPanel"
                            Grid.Row="3"
                            Background="#202C33"
                            CornerRadius="10"
                            Padding="15"
                            Margin="0,10,0,0"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="QuizFinalScoreText"
                                       Foreground="#25D366"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       TextAlignment="Center"/>
                            <TextBlock x:Name="QuizFinalMessageText"
                                       Foreground="White"
                                       FontSize="16"
                                       TextAlignment="Center"
                                       Margin="0,10,0,0"/>
                            <Button Content="🔄 Try Again"
                                    Style="{StaticResource GreenButtonStyle}"
                                    HorizontalAlignment="Center"
                                    Margin="0,15,0,0"
                                    Click="StartQuizButton_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ========================================= -->
            <!-- TAB 4: ACTIVITY LOG -->
            <!-- ========================================= -->
            <TabItem Header="📜 Activity Log">
                <Grid Margin="10" Background="#111B21">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Grid.Row="0"
                               Text="Activity Log"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#25D366"
                               Margin="0,0,0,10"/>

                    <!-- Controls -->
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <Button x:Name="RefreshLogButton"
                                Content="🔄 Refresh Log"
                                Style="{StaticResource GrayButtonStyle}"
                                Padding="15,10"
                                Margin="0,0,10,0"
                                Click="RefreshLogButton_Click"/>

                        <Button x:Name="ShowFullLogButton"
                                Content="📋 Show Full Log"
                                Style="{StaticResource GreenButtonStyle}"
                                Padding="15,10"
                                Click="ShowFullLogButton_Click"
                                Visibility="Collapsed"/>

                        <TextBlock x:Name="LogCountText"
                                   Foreground="Gray"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="20,0,0,0"/>
                    </StackPanel>

                    <!-- Log Display -->
                    <Border Grid.Row="2"
                            Background="#202C33"
                            CornerRadius="10"
                            Padding="15">
                        <Border Background="#111B21"
                                CornerRadius="5">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="LogDisplayText"
                                           Foreground="White"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Padding="10"/>
                            </ScrollViewer>
                        </Border>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
    </Window>
